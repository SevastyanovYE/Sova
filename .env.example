SOVA_TIMEZONE=Europe/Moscow
SOVA_STATE_DIR=.state
SOVA_DATABASE_PATH=.state/sova.db
SOVA_OVERVIEW_COOLDOWN=15m
SOVA_DAILY_RUN_TIME=08:00

# Dedicated MTProto project session. Never point this at Telegram Desktop tdata.
SOVA_TELEGRAM_APP_ID=
SOVA_TELEGRAM_APP_HASH=
SOVA_TELEGRAM_PHONE=
SOVA_TELEGRAM_SESSION_PATH=.sessions/sova-user.json

# Sova Nest study digest sources. Comma/semicolon/newline separated.
# Prefer @username or t.me/name; explicit refs are also accepted as
# chat:<id> or channel:<id>:<access_hash>.
SOVA_NEST_TELEGRAM_ALLOWED_CHATS=

# Sova Nest Bot API and forum topic identifiers.
SOVA_NEST_BOT_TOKEN=
SOVA_NEST_CHAT_ID=
SOVA_NEST_TOPIC_DIGEST_ID=
SOVA_NEST_TOPIC_CALENDAR_ID=
SOVA_NEST_TOPIC_STATUS_ID=
SOVA_NEST_TOPIC_CHAT_ID=

# Sova.Workspace foundation. Legacy source is the old InSync archive source,
# accepted in the same forms as SOVA_NEST_TELEGRAM_ALLOWED_CHATS. Keep personal
# Workspace sources here, not in the Sova Nest study digest allowlist.
# Topic IDs can be generated with `sova workspace bootstrap-topics`.
SOVA_WORKSPACE_BOT_TOKEN=
SOVA_WORKSPACE_LEGACY_SOURCE=
SOVA_WORKSPACE_CHAT_ID=
SOVA_WORKSPACE_TOPIC_INBOX_ID=
SOVA_WORKSPACE_TOPIC_TASKS_ID=
SOVA_WORKSPACE_TOPIC_NOTES_ID=
SOVA_WORKSPACE_TOPIC_EXPERIENCE_ID=
SOVA_WORKSPACE_TOPIC_USEFUL_ID=
SOVA_WORKSPACE_TOPIC_TEMPLATES_ID=
SOVA_WORKSPACE_TOPIC_COLLECTIONS_ID=

# Sova.Control service group.
# Topic IDs can be generated with `sova workspace bootstrap-topics`.
SOVA_CONTROL_BOT_TOKEN=
SOVA_CONTROL_CHAT_ID=
SOVA_CONTROL_TOPIC_STATUS_ID=
SOVA_CONTROL_TOPIC_ERRORS_ID=
SOVA_CONTROL_TOPIC_RUNS_ID=
SOVA_CONTROL_TOPIC_REVIEW_ID=
SOVA_CONTROL_TOPIC_TEST_LAB_ID=
SOVA_CONTROL_TOPIC_WORKSPACE_ID=
SOVA_CONTROL_TOPIC_NEST_ID=
SOVA_CONTROL_TOPIC_IDEAS_ID=

SOVA_OLLAMA_URL=http://127.0.0.1:11434
SOVA_OLLAMA_MODEL=qwen3:14b

# Optional Gemini formatting backend for Workspace publish preview.
# Leave empty to use the local mock formatter.
SOVA_GEMINI_API_KEY=
SOVA_GEMINI_MODEL=

# Optional custom Codex CLI path. PATH and the standard macOS app are auto-detected.
SOVA_CODEX_PATH=

# Google OAuth Desktop credentials and local token.
SOVA_GOOGLE_CREDENTIALS_PATH=.secrets/google-calendar-client.json
SOVA_GOOGLE_TOKEN_PATH=.secrets/google-calendar-token.json
SOVA_GOOGLE_CALENDAR_ID=
