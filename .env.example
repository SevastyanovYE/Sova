SOVA_TIMEZONE=Europe/Moscow
SOVA_STATE_DIR=.state
SOVA_DATABASE_PATH=.state/sova.db
SOVA_OVERVIEW_COOLDOWN=15m
SOVA_DAILY_RUN_TIME=08:00

# Dedicated MTProto project session. Never point this at Telegram Desktop tdata.
SOVA_TELEGRAM_APP_ID=
SOVA_TELEGRAM_APP_HASH=
SOVA_TELEGRAM_PHONE=
SOVA_TELEGRAM_SESSION_PATH=.sessions/sova-user.json
# Comma/semicolon/newline separated. Prefer @username or t.me/name; explicit
# refs are also accepted as chat:<id> or channel:<id>:<access_hash>.
SOVA_TELEGRAM_ALLOWED_CHATS=

# Sova Nest Bot API and forum topic identifiers.
SOVA_NEST_BOT_TOKEN=
SOVA_NEST_CHAT_ID=
SOVA_NEST_TOPIC_DIGEST_ID=
SOVA_NEST_TOPIC_CALENDAR_ID=
SOVA_NEST_TOPIC_STATUS_ID=
SOVA_NEST_TOPIC_CHAT_ID=

SOVA_OLLAMA_URL=http://127.0.0.1:11434
SOVA_OLLAMA_MODEL=qwen3:14b

# Optional custom Codex CLI path. PATH and the standard macOS app are auto-detected.
SOVA_CODEX_PATH=

# Google OAuth Desktop credentials and local token.
SOVA_GOOGLE_CREDENTIALS_PATH=.secrets/google-calendar-client.json
SOVA_GOOGLE_TOKEN_PATH=.secrets/google-calendar-token.json
SOVA_GOOGLE_CALENDAR_ID=
